# Copy this file to .env and fill in your values

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Auth — change this to a random 32+ char string in production
JWT_SECRET=classvision-change-this-in-production-min32chars
TOKEN_EXPIRE_HOURS=8

# Default admin (created on first run if no users exist)
ADMIN_EMAIL=admin@classvision.local
ADMIN_PASSWORD=admin123

# Face recognition strictness: 0.4 = strict, 0.5 = balanced, 0.6 = lenient
FACE_TOLERANCE=0.5

# Database
DATABASE_URL=sqlite:///./classvision.db

# Email (for report sending) — use Gmail App Password or any SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your@gmail.com

# Face recognition similarity threshold (0.75–0.90 recommended)
FACE_SIMILARITY=0.82
